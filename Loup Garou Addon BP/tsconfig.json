{
  "compilerOptions": {
    "module": "ES2020",
    "target": "ES2021",
    "moduleResolution": "Node",
    "allowSyntheticDefaultImports": true,
    "noEmitOnError": false,
    "baseUrl": "./src",
    "rootDir": "./src",
    "outDir": "./scripts",
    "resolveJsonModule": true
  },
  "include": [
    "src/**/*",
    "src/types.d.ts"
  ]
}
